{
  "name": "gemini-cli-multi-account",
  "version": "1.0.0",
  "description": "Gemini CLI proxy with multi-account rotation and Cloudflare Workers deployment",
  "main": "src/index.ts",
  "scripts": {
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "lint": "eslint --ext .ts src",
    "auth:add": "node authenticate.js add",
    "auth:list": "node authenticate.js list",
    "auth:remove": "node authenticate.js remove",
    "setup:deploy": "node setup-accounts.js deploy",
    "setup:deploy-all": "node setup-accounts.js deploy-all",
    "setup:list-kv": "node setup-accounts.js list-kv",
    "setup:remove-kv": "node setup-accounts.js remove-kv",
    "setup:health": "node setup-accounts.js health",
    "secrets:update": "node manage-secrets.js",
    "secrets:list": "node manage-secrets.js list"
  },
  "dependencies": {
    "hono": "^4.9.2",
    "open": "^8.4.2",
    "qrcode-terminal": "^0.12.0",
    "toml": "^3.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250816.0",
    "@types/node": "^24.3.0",
    "typescript": "^5.4.5",
    "wrangler": "^4.30.0"
  }
}
